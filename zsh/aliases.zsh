# Éditeur
alias vim='nvim'

# sshm : ne lister que mes hôtes
alias sshm='sshm -c ~/.ssh/config'

# Fichiers
alias mkdir='mkdir -p'
alias ls='eza --icons'
alias ll='eza -la --icons --git'
alias tree='eza --tree --icons'
alias grep='grep --color=auto'

# L'espace final permet d'utiliser un alias juste après sudo / watch
alias sudo='sudo '
alias watch='watch '
